# Dimed-PAGO — variables de entorno (copiar a .env y completar)
# 'dimed' = rol dueño (solo para migraciones / contenedor init).
PG_PASSWORD=cambia_esta_clave
# Rol de aplicacion de menor privilegio (solo DML): lo usa el servicio pago.
# Genera uno distinto: python3 -c "import secrets; print(secrets.token_hex(24))"
APP_DB_PASSWORD=cambia_esta_clave_app_db
JWT_SECRET=cambia_este_secreto_largo_y_aleatorio

# Puerto web (host). Por defecto 9850.
WEB_PORT=9850

# URL publica con la que se construyen los enlaces de pago que se envian a los
# clientes (WhatsApp/email). En produccion: https://pagos.tudominio.com
PUBLIC_BASE_URL=http://localhost:9850

# Pasarela de tarjetas activa: 'sandbox' (simulada, sin dinero real) o 'paypal'.
GATEWAY=sandbox

# PayPal (GATEWAY=paypal): credenciales REST de https://developer.paypal.com
# → Apps & Credentials → pestaña Live → Create App → Client ID + Secret.
# El CLIENT_ID es publico (va en la pagina de pago); el SECRET jamas se comparte.
# PAYPAL_ENV=sandbox usa el entorno de prueba de PayPal (cuentas ficticias).
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Tamano maximo (MB) del comprobante de transferencia que sube el pagador.
MAX_UPLOAD_MB=10

FLASK_DEBUG=0
